#include <stdio.h>
#include <string.h>

#define MAX_TASKS 10
#define MAX_LEN 50

struct Task {
    char title[MAX_LEN];
    int done;
};

int main() {
    struct Task list[MAX_TASKS];
    int count = 0;
    int choice;

    while (1) {
        printf("\n1. Add Task\n2. View Tasks\n3. Mark Done\n4. Exit\nChoice: ");
        scanf("%d", &choice);
        getchar();

        if (choice == 1 && count < MAX_TASKS) {
            printf("Enter task: ");
            fgets(list[count].title, MAX_LEN, stdin);
            list[count].title[strcspn(list[count].title, "\n")] = 0;
            list[count].done = 0;
            count++;
        } else if (choice == 2) {
            for (int i = 0; i < count; i++) {
                printf("%d. [%c] %s\n", i + 1, list[i].done ? 'X' : ' ', list[i].title);
            }
        } else if (choice == 3) {
            int num;
            printf("Task number: ");
            scanf("%d", &num);
            if (num > 0 && num <= count) list[num - 1].done = 1;
        } else if (choice == 4) {
            break;
        }
    }
    return 0;
}
